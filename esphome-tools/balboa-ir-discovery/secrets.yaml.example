# Fichier de secrets pour ESPHome
# Copiez ce fichier vers secrets.yaml et remplissez vos valeurs

# Configuration Wi-Fi
wifi_ssid: "VotreSSID"
wifi_password: "VotreMotDePasse"

# Clé de chiffrement API (générez-en une avec: openssl rand -base64 32)
api_encryption_key: "votre_cle_api_32_caracteres_base64=="

# Mot de passe OTA (pour les mises à jour sans fil)
ota_password: "votre_mot_de_passe_ota"
