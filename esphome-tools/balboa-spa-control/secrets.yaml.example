# Fichier de secrets pour ESPHome — balboa-spa-control
# Copiez ce fichier vers secrets.yaml et remplissez vos valeurs.
# Le fichier secrets.yaml est ignore par git (.gitignore).

# Configuration Wi-Fi principale
wifi_ssid: "VotreSSID"
wifi_password: "VotreMotDePasse"

# Mot de passe du point d'acces de secours (mode fallback "Balboa-Fallback")
ap_password: "VotreMotDePasseFallback"

# Cle de chiffrement API (32 octets en base64)
# Generer avec : openssl rand -base64 32
api_encryption_key: "votre_cle_api_32_octets_base64=="

# Mot de passe OTA (pour les mises a jour sans fil)
ota_password: "votre_mot_de_passe_ota"
